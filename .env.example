# GrapplingWiki Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your .env file to Git!

# Flask configuration
FLASK_CONFIG=development          # development | production | testing
SECRET_KEY=change-this-to-a-random-string

# Database
DATABASE_URL=sqlite:///instance/grappling_wiki.db   # Use PostgreSQL URL in production

# Site settings
SITE_URL=http://localhost:5000    # Your production URL when deployed
